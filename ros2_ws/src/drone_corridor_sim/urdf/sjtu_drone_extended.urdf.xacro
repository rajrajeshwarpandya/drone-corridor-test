<?xml version="1.0"?>
<robot name="sjtu_drone_extended"
       xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- Base drone (has GPS via built-in plugin, IMU, sonar, flight dynamics) -->
  <xacro:include filename="$(find sjtu_drone_description)/urdf/sjtu_drone.urdf.xacro"/>

  <!-- ── DOWNWARD-FACING 2D RGB CAMERA ────────────────────── -->
  <link name="downward_cam_link">
    <inertial>
      <mass value="0.001"/>
      <inertia ixx="1e-7" ixy="0" ixz="0" iyy="1e-7" iyz="0" izz="1e-7"/>
    </inertial>
  </link>
  <joint name="downward_cam_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="downward_cam_link"/>
    <!-- Mounted underneath, pointing straight down (pitch -90°) -->
    <origin xyz="0.0 0.0 -0.05" rpy="0 1.5707963 0"/>
  </joint>
  <gazebo reference="downward_cam_link">
    <sensor name="downward_camera" type="camera">
      <always_on>true</always_on>
      <update_rate>15</update_rate>
      <visualize>true</visualize>
      <camera>
        <horizontal_fov>1.5708</horizontal_fov>  <!-- 90° FOV -->
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.1</near>
          <far>50.0</far>
        </clip>
      </camera>
      <plugin name="downward_cam_plugin" filename="libgazebo_ros_camera.so">
        <ros>
          <namespace>/drone</namespace>
          <remapping>~/image_raw:=downward_cam/image_raw</remapping>
          <remapping>~/camera_info:=downward_cam/camera_info</remapping>
        </ros>
        <camera_name>downward_cam</camera_name>
        <frame_name>downward_cam_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <!-- ── GPS (invisible) ─────────────────────────────────────── -->
  <link name="gps_link">
    <inertial>
      <mass value="0.001"/>
      <inertia ixx="1e-7" ixy="0" ixz="0" iyy="1e-7" iyz="0" izz="1e-7"/>
    </inertial>
  </link>
  <joint name="gps_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="gps_link"/>
    <origin xyz="0 0 0.1" rpy="0 0 0"/>
  </joint>
  <gazebo reference="gps_link">
    <sensor name="gps_sensor" type="gps">
      <always_on>true</always_on>
      <update_rate>5</update_rate>
      <gps>
        <position_sensing>
          <horizontal><noise type="gaussian"><mean>0</mean><stddev>0.5</stddev></noise></horizontal>
          <vertical><noise type="gaussian"><mean>0</mean><stddev>1.0</stddev></noise></vertical>
        </position_sensing>
      </gps>
      <plugin name="gps_plugin" filename="libgazebo_ros_gps_sensor.so">
        <ros><namespace>/drone</namespace><remapping>~/out:=gps/fix</remapping></ros>
        <frame_name>gps_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>

</robot>
